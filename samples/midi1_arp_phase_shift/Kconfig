menu "MIDI 1.0 ARP sample"

config MIDI1_ARP_NUMBER_OF_NOTES
    int "ARP number of NOTES to support"
    default 10
    range 1 32
    
config MIDI1_ARP_TIMING_INTERVAL
    int "TIMING_INTERVAL"
    default 6
    range 1 128
    
config MIDI1_ARP_TARGET_BPM
    int "Default ARP beats per minute (BPM) * 100 (i.e. 120 bpm is 12000)"
    default 10000
    range 1 60000

config MIDI1_ARP_DRIFT_CYCLE
    int "Number of MIDI clock ticks to drift" 
    default 8
    range 1 96

config MIDI1_ARP_TEMPO_MINIMUM 
    int "Minimum tempo using the ADC pot input default is 30.00 bpm (3000)" 
    default 3000 
    range 100 30000

config MIDI1_ARP_TEMPO_MAXIMUM 
    int "Maximum tempo using the ADC pot input default is 300.00 bpm (30000)" 
    default 30000 
    range 100 30000

config MIDI1_ARP_TEMPO_DEADBAND
	int "The ADC can be noisy don't change the tempo unless it has changed more than this" 
	default 50
	range 1 500

endmenu

source "Kconfig.zephyr"
